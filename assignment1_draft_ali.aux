\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces The environment as described in \autoref {sec:experiments} when initialising the $Q$ table with zeros for all actions $a$ and states $s$. The agent will start at the blue square with an S in the top-left. The goal is denoted by the green square with a +100 in the top. In this setting the agent will move around randomly until it's reached a maximum number of steps or the goal is reached}}{4}{figure.2}\protected@file@percent }
\newlabel{fig:value_iteration_beginning}{{2}{4}{The environment as described in \autoref {sec:experiments} when initialising the $Q$ table with zeros for all actions $a$ and states $s$. The agent will start at the blue square with an S in the top-left. The goal is denoted by the green square with a +100 in the top. In this setting the agent will move around randomly until it's reached a maximum number of steps or the goal is reached}{figure.2}{}}
\newlabel{fig:value_iteration_beginning@cref}{{[figure][2][]2}{[1][4][]4}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Similar to \autoref {fig:value_iteration_beginning}, but now the value iteration algorithm (described in \autoref {subsec:dynamic_programming} is halfway through its iterations (having performed 8 of the 16 iterations until convergence is reached). This is visible by the fact that not every state has an optimal action yet (the optimal action is denoted by an arrow in the direction of the optimal action). With this $Q$ table the agent will move to the right, be moved upwards by the wind, then move down to the bottom-right and then go left and up towards the goal state.}}{4}{figure.3}\protected@file@percent }
\newlabel{fig:value_iteration_halfway}{{3}{4}{Similar to \autoref {fig:value_iteration_beginning}, but now the value iteration algorithm (described in \autoref {subsec:dynamic_programming} is halfway through its iterations (having performed 8 of the 16 iterations until convergence is reached). This is visible by the fact that not every state has an optimal action yet (the optimal action is denoted by an arrow in the direction of the optimal action). With this $Q$ table the agent will move to the right, be moved upwards by the wind, then move down to the bottom-right and then go left and up towards the goal state}{figure.3}{}}
\newlabel{fig:value_iteration_halfway@cref}{{[figure][3][]3}{[1][4][]4}{}{}{}}
